 index.html
<!DOCTYPE html>
<html>
<head>
<title>Vanguard Pack Opener</title>
</head>

<body>

<h1>Cardfight Vanguard Pack Opener</h1>

<select id="packSelect"></select>

<button onclick="openPack()">Open Pack</button>

<h2>Pulled Cards</h2>
<div id="result"></div>

<script src="script.js"></script>

</body>
</html>
script.js
let packs = {};

fetch("packs.json")
.then(response => response.json())
.then(data => {
    packs = data;

    const select = document.getElementById("packSelect");

    for (let pack in packs) {
        let option = document.createElement("option");
        option.value = pack;
        option.textContent = pack;
        select.appendChild(option);
    }
});

function openPack(){

    const packName = document.getElementById("packSelect").value;
    const cards = packs[packName];

    const result = document.getElementById("result");
    result.innerHTML = "";

    for(let i=0;i<5;i++){

        let random = cards[Math.floor(Math.random()*cards.length)];

        let div = document.createElement("div");
        div.textContent = random;

        result.appendChild(div);
    }
}
