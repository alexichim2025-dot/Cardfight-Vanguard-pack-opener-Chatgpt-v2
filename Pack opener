let packs = {};

fetch("packs.json")
.then(response => {
    if(!response.ok){
        throw new Error("packs.json could not be loaded");
    }
    return response.json();
})
.then(data => {
    packs = data;

    const select = document.getElementById("packSelect");

    for (let pack in packs) {
        let option = document.createElement("option");
        option.value = pack;
        option.textContent = pack;
        select.appendChild(option);
    }
})
.catch(error => {
    console.error(error);
});

function openPack(){

    const packName = document.getElementById("packSelect").value;
    const cards = packs[packName];

    if(!cards){
        alert("Pack not loaded yet!");
        return;
    }

    const result = document.getElementById("result");
    result.innerHTML = "";

    for(let i=0;i<5;i++){

        let random = cards[Math.floor(Math.random()*cards.length)];

        let div = document.createElement("div");
        div.textContent = random;

        result.appendChild(div);
    }
}
